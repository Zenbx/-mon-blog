---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const featured = sorted.find(p => p.data.featured) ?? sorted[0];
const rest = sorted.filter(p => p.id !== featured?.id);
---

<BaseLayout
  title="Jeff Belekotan — Blog"
  description="Personal blog by Jeff Belekotan — web developer writing about performance, DX and modern tooling."
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16 border-b border-zinc-100 dark:border-zinc-800">
    <p class="text-sm font-medium text-zinc-400 dark:text-zinc-500 uppercase tracking-widest mb-4">Blog</p>
    <h1 class="text-5xl font-bold text-zinc-900 dark:text-zinc-50 tracking-tight leading-tight mb-5">
      Jeff Belekotan
    </h1>
    <p class="text-xl text-zinc-500 dark:text-zinc-400 max-w-lg leading-relaxed">
      Web developer — I write about performance, DX and modern tooling.
    </p>
  </section>

  <!-- Featured article -->
  {featured && (
    <section class="max-w-5xl mx-auto px-6 pt-14 pb-14 border-b border-zinc-100 dark:border-zinc-800">
      <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-8">Featured</p>
      <ArticleCard post={featured} large />
    </section>
  )}

  <!-- Article grid -->
  {rest.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pt-14 pb-24">
      <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-8">
        Latest articles
      </p>
      <div class="grid sm:grid-cols-2 gap-10">
        {rest.map(post => <ArticleCard post={post} />)}
      </div>
    </section>
  )}
</BaseLayout>
