---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const skills = [
  { label: 'Web Development', items: ['React', 'Astro', 'Next.js', 'TypeScript', 'Tailwind CSS'] },
  { label: 'Mobile Development', items: ['React Native', 'Expo'] },
  { label: 'Back-end', items: ['Node.js', 'Express', 'REST API', 'GraphQL'] },
  { label: 'Learning', items: ['Distributed Systems', 'DevOps', 'Docker', 'Kubernetes', 'CI/CD'] },
];
---

<BaseLayout
  title="About — Jeff Belekotan"
  description="Computer Engineering Student, Full-Stack Web and Mobile Developer."
>
  <div class="max-w-2xl mx-auto px-6 py-16">
    <!-- Identity -->
    <div class="flex items-center gap-5 mb-12">
      <div class="w-16 h-16 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-2xl font-bold text-zinc-600 dark:text-zinc-400 shrink-0">
        J
      </div>
      <div>
        <h1 class="text-2xl font-bold text-zinc-900 dark:text-zinc-50 tracking-tight">
          Belekotan II Jeff Nichoss
        </h1>
        <p class="text-zinc-500 dark:text-zinc-400 text-sm mt-1">Computer Engineering Student</p>
      </div>
    </div>

    <!-- Bio -->
    <div class="article-body mb-14">
      <p>
        Full-Stack <strong>Web and Mobile</strong> developer, I build modern applications
        with a strong focus on performance and developer experience.
      </p>
      <p>
        Currently doing a deep dive into <strong>Distributed Systems</strong> and
        <strong>DevOps</strong> — containerization, orchestration, continuous integration
        and deployment.
      </p>
      <p>
        This blog is my logbook: I document what I learn, the tools I explore,
        and the problems I solve along the way.
      </p>
    </div>

    <!-- Skills -->
    <div class="mb-14">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-6">
        Skills
      </h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {skills.map(({ label, items }) => (
          <div>
            <p class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 mb-2">{label}</p>
            <div class="flex flex-wrap gap-2">
              {items.map(item => (
                <span class="px-2 py-0.5 text-xs bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 rounded-full">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Links -->
    <div>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-6">
        Find me
      </h2>
      <div class="flex flex-col gap-3 text-sm">
        <a
          href="https://github.com/Zenbx"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
        >
          <span class="w-8 text-zinc-400 dark:text-zinc-500 font-mono text-xs">GH</span>
          github.com/Zenbx
        </a>
        <a
          href="https://twitter.com/Zenbx"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
        >
          <span class="w-8 text-zinc-400 dark:text-zinc-500 font-mono text-xs">X</span>
          @Zenbx
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
