---
export interface Props {
  post: any;
  large?: boolean;
}

const { post, large = false } = Astro.props;
const { title, description, pubDate, cover, tags, readingTime } = post.data;
const base = import.meta.env.BASE_URL;
const slug = post.id.replace(/\.mdx?$/, '');
const href = `${base}blog/${slug}`;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

{large ? (
  <a href={href} class="group block">
    {cover && (
      <div class="mb-6 overflow-hidden rounded-xl aspect-video bg-zinc-100 dark:bg-zinc-800">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
        />
      </div>
    )}
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag: string) => (
        <span class="text-[11px] font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
          {tag}
        </span>
      ))}
    </div>
    <h2 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 leading-tight tracking-tight mb-3 group-hover:underline underline-offset-4 decoration-2">
      {title}
    </h2>
    <p class="text-zinc-500 dark:text-zinc-400 text-lg leading-relaxed mb-5 max-w-2xl">{description}</p>
    <div class="flex items-center gap-3 text-sm text-zinc-400 dark:text-zinc-500">
      <time datetime={new Date(pubDate).toISOString()}>{formattedDate}</time>
      {readingTime && (
        <>
          <span class="w-1 h-1 rounded-full bg-zinc-200 dark:bg-zinc-700" aria-hidden="true" />
          <span>{readingTime} min read</span>
        </>
      )}
      <span class="ml-auto inline-flex items-center gap-1.5 text-zinc-900 dark:text-zinc-100 font-medium text-sm group-hover:gap-3 transition-all duration-200">
        Read article <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
) : (
  <a href={href} class="group flex flex-col gap-2 pb-8 border-b border-zinc-100 dark:border-zinc-800 cursor-pointer">
    {cover && (
      <div class="overflow-hidden rounded-lg aspect-video bg-zinc-100 dark:bg-zinc-800 mb-1">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
        />
      </div>
    )}
    {tags.length > 0 && (
      <div class="flex items-center gap-2 flex-wrap">
        {tags.slice(0, 3).map((tag: string) => (
          <span class="text-[11px] font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
            {tag}
          </span>
        ))}
      </div>
    )}
    <h2 class="text-lg font-bold text-zinc-900 dark:text-zinc-100 leading-snug group-hover:underline underline-offset-4 decoration-2">
      {title}
    </h2>
    <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed line-clamp-2">{description}</p>
    <div class="flex items-center justify-between text-xs text-zinc-400 dark:text-zinc-500 pt-1">
      <div class="flex items-center gap-2">
        <time datetime={new Date(pubDate).toISOString()}>{formattedDate}</time>
        {readingTime && <span>· {readingTime} min</span>}
      </div>
      <span
        class="text-zinc-300 dark:text-zinc-600 group-hover:text-zinc-800 dark:group-hover:text-zinc-300 group-hover:translate-x-0.5 transition-all duration-150"
        aria-hidden="true"
      >→</span>
    </div>
  </a>
)}
