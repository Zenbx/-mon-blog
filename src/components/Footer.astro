---
const year = new Date().getFullYear();
---
<footer class="border-t border-zinc-100 dark:border-zinc-800 mt-24 transition-colors duration-200">
  <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-zinc-400 dark:text-zinc-500">
    <span>© {year} Jeff Belekotan</span>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/Zenbx"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
      >
        GitHub
      </a>
      <a
        href="https://twitter.com/Zenbx"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
      >
        X / Twitter
      </a>
    </div>
  </div>
</footer>
