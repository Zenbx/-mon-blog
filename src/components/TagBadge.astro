---
export interface Props {
  tag: string;
}
const { tag } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<a
  href={`${base}tags/${tag}`}
  class="inline-block px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 rounded-full hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
>
  {tag}
</a>
